)
print(fit_gamma, pars = c("shape", "rate", "beta"))
# 5. Extract posterior medians
post_gamma <- rstan::extract(fit_gamma)
shape_medians <- apply(post_gamma$shape, 2, median)
rate_medians <- apply(post_gamma$rate, 2, median)
beta_median <- median(post_gamma$beta[,1])
p_seropos <- plogis(beta_median)
pi <- c(1 - p_seropos, p_seropos)
# 6. Calculate means and SDs of Gamma components on original scale
mu <- shape_medians / rate_medians
sd <- sqrt(shape_medians) / rate_medians
cat("Mixing proportions (pi): ", round(pi, 3), "\n")
cat("Means (mu) on original scale: ", round(mu, 3), "\n")
cat("Standard deviations (sd) on original scale: ", round(sd, 3), "\n")
# 7. Identifiability/separation measure on original scale
muI <- max(mu)
muS <- min(mu)
SigI <- sd[which.max(mu)]
SigS <- sd[which.min(mu)]
sep <- abs(muI - muS) / sqrt(SigS^2 + SigI^2)
cat("Separation measure: ", round(sep, 3), "\n")
# 8. Find crossover point on original scale by weighted gamma densities difference
x_vals <- seq(min(gamma_data), max(gamma_data), length.out = 1000)
dens_diff <- function(x) {
pi[1] * dgamma(x, shape = shape_medians[1], rate = rate_medians[1]) -
pi[2] * dgamma(x, shape = shape_medians[2], rate = rate_medians[2])
}
crossover_original <- uniroot(dens_diff, lower = min(x_vals), upper = max(x_vals))$root
cat("Crossover point (original scale): ", round(crossover_original, 3), "\n")
# 9. Convert crossover to log scale (to classify seropositive on log scale)
crossover_log <- log(crossover_original)
# Classify seropositive based on crossover on log scale
seropositive <- asembodata_clean$log_antibody > crossover_log
seroprevalence <- mean(seropositive, na.rm = TRUE)
cat("Estimated seroprevalence (Gamma, log scale cutoff): ", round(seroprevalence * 100, 2), "%\n")
# 10. Plot histogram and densities on log scale
dens_neg <- pi[1] * dgamma(x_vals, shape = shape_medians[1], rate = rate_medians[1])
dens_pos <- pi[2] * dgamma(x_vals, shape = shape_medians[2], rate = rate_medians[2])
dens_mix <- dens_neg + dens_pos
df_plot <- data.frame(
x_log = log(x_vals),
dens_neg = dens_neg,
dens_pos = dens_pos,
dens_mix = dens_mix
)
ggplot(df_plot, aes(x = x_log)) +
geom_histogram(data = data.frame(log_antibody = asembodata_clean$log_antibody),
aes(x = log_antibody, y = ..density..),
bins = 30, fill = "white", color = "grey60", alpha = 0.5) +
geom_line(aes(y = dens_mix), color = "black", size = 1) +
geom_area(aes(y = dens_neg), fill = "red", alpha = 0.3) +
geom_area(aes(y = dens_pos), fill = "blue", alpha = 0.3) +
geom_vline(xintercept = crossover_log, linetype = "dashed", color = "black", size = 1) +
annotate("text", x = crossover_log, y = max(dens_mix) * 0.9,
label = paste0("Crossover = ", round(crossover_log, 2)),
hjust = -0.1) +
labs(title = "Bayesian 2-Component Gamma Mixture Model Density (log scale)",
x = "log(CHKV_AIU + 1)",
y = "Density") +
theme_minimal()
