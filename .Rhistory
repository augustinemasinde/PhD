age_yr >= 35 & age_yr <= 44 ~ "35-44",
age_yr >= 45 & age_yr <= 54 ~ "45-54",
age_yr >= 55 & age_yr <= 64 ~ "55-64",
TRUE ~ NA_character_
)
)
#create age categories and count samples in each sex, province, agecat combination
regional_samples  <-KNBTS %>%
