library(rstan)
library(ggplot2)
options(mc.cores = parallel::detectCores())
rstan_options(auto_write = TRUE)
# Filter and log-transform data consistently
asembodata_clean <- Asembodata[Asembodata$CHKV_AIU > 0 & !is.na(Asembodata$CHKV_AIU), ]
asembodata_clean$log_antibody <- log(asembodata_clean$CHKV_AIU + 1)
log_antibody_vals <- asembodata_clean$log_antibody
stan_data_gamma <- list(
N = length(log_antibody_vals),
y = log_antibody_vals,  # Log-transformed data
K = 1,
X = matrix(1, nrow = length(log_antibody_vals), ncol = 1)
)
stan_code_gamma <- "
functions {
real expit(real x) {
return inv_logit(x);
}
}
data {
int<lower=1> N;
vector<lower=0>[N] y;  // Log-scale positive data
int<lower=1> K;
matrix[N, K] X;
}
parameters {
vector[K] beta;
ordered[2] shape;          // shape for Gamma components
vector<lower=0>[2] rate;  // rate for Gamma components
}
model {
beta ~ normal(0, 1.5);
shape[1] ~ normal(2, 1);
shape[2] ~ normal(5, 2);
rate ~ gamma(2, 0.5);
for (n in 1:N) {
real p = expit(X[n] * beta);
target += log_sum_exp(
log1m(p) + gamma_lpdf(y[n] | shape[1], rate[1]),
log(p) + gamma_lpdf(y[n] | shape[2], rate[2])
);
}
}
generated quantities {
vector[N] log_lik;
vector[N] p_seropos;
for (n in 1:N) {
real p = expit(X[n] * beta);
real lp0 = log1m(p) + gamma_lpdf(y[n] | shape[1], rate[1]);
real lp1 = log(p) + gamma_lpdf(y[n] | shape[2], rate[2]);
log_lik[n] = log_sum_exp(lp0, lp1);
p_seropos[n] = exp(lp1 - log_lik[n]);
}
}
"
compiled_model_gamma <- stan_model(model_code = stan_code_gamma)
fit_gamma <- sampling(
compiled_model_gamma,
data = stan_data_gamma,
chains = 2,
iter = 4000,
warmup = 2000,
control = list(adapt_delta = 0.95),
seed = 123
)
print(fit_gamma, pars = c("shape", "rate", "beta"))
post_gamma <- rstan::extract(fit_gamma)
# Use posterior medians (not means)
shape_vals <- apply(post_gamma$shape, 2, median)
rate_vals <- apply(post_gamma$rate, 2, median)
beta_median <- median(post_gamma$beta[,1])
# Mixing proportions
p_seropos <- plogis(beta_median)
pi <- c(1 - p_seropos, p_seropos)
# Compute Gamma means and sds on log scale:
# mean = shape / rate
mu <- shape_vals / rate_vals
# sd = sqrt(shape) / rate
sd <- sqrt(shape_vals) / rate_vals
cat("Mixing proportions (pi): ", round(pi, 3), "\n")
cat("Means (mu) on log scale: ", round(mu, 3), "\n")
cat("Standard deviations (sd) on log scale: ", round(sd, 3), "\n")
# Identifiability check (separation)
muI <- max(mu)
muS <- min(mu)
SigI <- sd[which.max(mu)]
SigS <- sd[which.min(mu)]
sep <- abs(muI - muS) / sqrt(SigS^2 + SigI^2)
cat("Separation measure (log scale): ", round(sep, 3), "\n")
# Crossover calculation on log scale
x_vals <- seq(min(log_antibody_vals), max(log_antibody_vals), length.out = 1000)
dens_diff <- function(x) {
pi[1] * dgamma(x, shape = shape_vals[1], rate = rate_vals[1]) -
pi[2] * dgamma(x, shape = shape_vals[2], rate = rate_vals[2])
}
crossover_log <- uniroot(dens_diff, lower = min(x_vals), upper = max(x_vals))$root
cat("Crossover point (log scale): ", round(crossover_log, 3), "\n")
# Classify seropositive
seropositive <- log_antibody_vals > crossover_log
seroprevalence <- mean(seropositive, na.rm = TRUE)
cat("Estimated seroprevalence (log scale threshold): ", round(seroprevalence * 100, 2), "%\n")
# Prepare data for plotting
dens_neg <- pi[1] * dgamma(x_vals, shape = shape_vals[1], rate = rate_vals[1])
dens_pos <- pi[2] * dgamma(x_vals, shape = shape_vals[2], rate = rate_vals[2])
dens_mix <- dens_neg + dens_pos
df_plot <- data.frame(
x_log = x_vals,
dens_neg = dens_neg,
dens_pos = dens_pos,
dens_mix = dens_mix
)
# Plot histogram + densities + crossover (all on log scale)
ggplot(df_plot, aes(x = x_log)) +
geom_histogram(data = data.frame(log_antibody_vals), aes(x = log_antibody_vals, y = ..density..),
bins = 30, fill = "white", color = "grey60", alpha = 0.5) +
geom_line(aes(y = dens_mix), color = "black", size = 1) +
geom_area(aes(y = dens_neg), fill = "red", alpha = 0.3) +
geom_area(aes(y = dens_pos), fill = "blue", alpha = 0.3) +
geom_vline(xintercept = crossover_log, linetype = "dashed", color = "black", size = 1) +
annotate("text", x = crossover_log, y = max(dens_mix) * 0.9,
label = paste0("Crossover = ", round(crossover_log, 2)), hjust = -0.1) +
labs(title = "Bayesian 2-Component Gamma Mixture Model Density (Log scale)",
x = "log(CHKV_AIU + 1)",
y = "Density") +
theme_minimal()
library(rstan)
library(ggplot2)
options(mc.cores = parallel::detectCores())
rstan_options(auto_write = TRUE)
# Prepare data: filter & log-transform
asembodata_clean <- Asembodata[Asembodata$CHKV_AIU > 0 & !is.na(Asembodata$CHKV_AIU), ]
asembodata_clean$log_antibody <- log(asembodata_clean$CHKV_AIU + 1)
log_antibody_vals <- asembodata_clean$log_antibody
stan_data_weibull <- list(
N = length(log_antibody_vals),
y = log_antibody_vals,  # Log scale
K = 1,
X = matrix(1, nrow = length(log_antibody_vals), ncol = 1)
)
stan_code_weibull <- "
functions {
real expit(real x) {
return inv_logit(x);
}
// Weibull log PDF with shape k and scale lambda
real weibull_lpdf_custom(real y, real k, real lambda) {
// y > 0, shape k > 0, scale lambda > 0
return log(k) - k * log(lambda) + (k - 1) * log(y) - pow(y / lambda, k);
}
}
data {
int<lower=1> N;
vector<lower=0>[N] y;  // positive log-transformed data
int<lower=1> K;
matrix[N, K] X;
}
parameters {
vector[K] beta;
ordered[2] shape;        // shape parameters k
vector<lower=0>[2] scale;  // scale parameters lambda
}
model {
beta ~ normal(0, 1.5);
shape[1] ~ normal(2, 1);
shape[2] ~ normal(5, 2);
scale ~ gamma(2, 0.5);
for (n in 1:N) {
real p = expit(X[n] * beta);
target += log_sum_exp(
log1m(p) + weibull_lpdf_custom(y[n] | shape[1], scale[1]),
log(p) + weibull_lpdf_custom(y[n] | shape[2], scale[2])
);
}
}
generated quantities {
vector[N] log_lik;
vector[N] p_seropos;
for (n in 1:N) {
real p = expit(X[n] * beta);
real lp0 = log1m(p) + weibull_lpdf_custom(y[n] | shape[1], scale[1]);
real lp1 = log(p) + weibull_lpdf_custom(y[n] | shape[2], scale[2]);
log_lik[n] = log_sum_exp(lp0, lp1);
p_seropos[n] = exp(lp1 - log_lik[n]);
}
}
"
compiled_model_weibull <- stan_model(model_code = stan_code_weibull)
