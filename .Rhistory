library(rstan)
library(ggplot2)
library(reshape2)
options(mc.cores = parallel::detectCores())
rstan_options(auto_write = TRUE)
# 1. Prepare data: filter positive & non-NA values and log-transform
asembodata_clean <- Asembodata[Asembodata$CHKV_AIU > 0 & !is.na(Asembodata$CHKV_AIU), ]
asembodata_clean$log_antibody <- log(asembodata_clean$CHKV_AIU + 1)
log_antibody_vals <- asembodata_clean$log_antibody
# 2. Prepare data list for Stan
stan_data_weibull <- list(
N = length(log_antibody_vals),
y = log_antibody_vals,  # positive data on log scale
K = 1,
X = matrix(1, nrow = length(log_antibody_vals), ncol = 1)
)
# 3. Stan model code for 2-component Weibull mixture
stan_code_weibull <- "
functions {
real expit(real x) {
return inv_logit(x);
}
}
data {
int<lower=1> N;
vector<lower=0>[N] y;
int<lower=1> K;
matrix[N, K] X;
}
parameters {
vector[K] beta;
vector<lower=0>[2] shape;
vector<lower=0>[2] scale;
}
model {
beta ~ normal(0, 1.5);
shape ~ normal(2, 1);
scale ~ normal(5, 2);
for (n in 1:N) {
real p = expit(X[n] * beta);
target += log_sum_exp(
log1m(p) + weibull_lpdf(y[n] | shape[1], scale[1]),
log(p) + weibull_lpdf(y[n] | shape[2], scale[2])
);
}
}
generated quantities {
vector[N] log_lik;
vector[N] p_seropos;
for (n in 1:N) {
real p = expit(X[n] * beta);
real lp0 = log1m(p) + weibull_lpdf(y[n] | shape[1], scale[1]);
real lp1 = log(p) + weibull_lpdf(y[n] | shape[2], scale[2]);
log_lik[n] = log_sum_exp(lp0, lp1);
p_seropos[n] = exp(lp1 - log_lik[n]);
}
}
"
# 4. Compile and fit model
compiled_model_weibull <- stan_model(model_code = stan_code_weibull)
fit_weibull <- sampling(
compiled_model_weibull,
data = stan_data_weibull,
chains = 2,
iter = 4000,
warmup = 2000,
control = list(adapt_delta = 0.95),
seed = 123
)
print(fit_weibull, pars = c("shape", "scale", "beta"))
# 5. Extract posterior samples
post_weibull <- rstan::extract(fit_weibull)
# 6. Compute posterior medians of parameters
shape_medians <- apply(post_weibull$shape, 2, median)
scale_medians <- apply(post_weibull$scale, 2, median)
beta_median <- median(post_weibull$beta[,1])
# 7. Calculate mixing probabilities
p_seropos <- plogis(beta_median)
pi <- c(1 - p_seropos, p_seropos)
cat("Mixing proportions (pi): ", round(pi, 3), "\n")
cat("Shape medians: ", round(shape_medians, 3), "\n")
cat("Scale medians: ", round(scale_medians, 3), "\n")
# Median of Weibull distribution = scale * (log(2))^(1/shape)
median_comp <- scale_medians * (log(2))^(1 / shape_medians)
# Variance = scale^2 * (Gamma(1 + 2/shape) - (Gamma(1 + 1/shape))^2)
# SD = sqrt(variance)
gamma1 <- gamma(1 + 1 / shape_medians)
gamma2 <- gamma(1 + 2 / shape_medians)
var_comp <- scale_medians^2 * (gamma2 - gamma1^2)
sd_comp <- sqrt(var_comp)
cat("Median values on log scale: ", round(median_comp, 3), "\n")
cat("SD values on log scale: ", round(sd_comp, 3), "\n")
# 9. Prepare sequence for densities (log scale)
x_vals <- seq(min(log_antibody_vals), max(log_antibody_vals), length.out = 1000)
# 10. Compute Weibull densities weighted by mixing proportions (on log scale)
dens_neg <- pi[1] * dweibull(x_vals, shape = shape_medians[1], scale = scale_medians[1])
dens_pos <- pi[2] * dweibull(x_vals, shape = shape_medians[2], scale = scale_medians[2])
dens_mix <- dens_neg + dens_pos
# 11. Define density difference function for crossover (log scale)
dens_diff <- function(x) {
pi[1] * dweibull(x, shape = shape_medians[1], scale = scale_medians[1]) -
pi[2] * dweibull(x, shape = shape_medians[2], scale = scale_medians[2])
}
# 12. Find crossover point on log scale
crossover_log <- uniroot(dens_diff, lower = min(x_vals), upper = max(x_vals))$root
cat("Crossover point (log scale): ", round(crossover_log, 3), "\n")
# 13. Classify seropositive based on crossover and calculate seroprevalence
seropositive <- log_antibody_vals > crossover_log
seroprevalence <- mean(seropositive, na.rm = TRUE)
cat("Estimated seroprevalence (log scale threshold): ", round(seroprevalence * 100, 2), "%\n")
# 14. Prepare data frame for plotting
df_plot <- data.frame(
x = x_vals,
dens_neg = dens_neg,
dens_pos = dens_pos,
dens_mix = dens_mix
)
# 15. Plot histogram and densities with crossover (all on log scale)
ggplot(df_plot, aes(x = x)) +
geom_histogram(data = data.frame(log_antibody_vals), aes(x = log_antibody_vals, y = ..density..),
bins = 30, fill = "white", color = "grey60", alpha = 0.5) +
geom_line(aes(y = dens_mix), color = "black", size = 1) +
geom_area(aes(y = dens_neg), fill = "red", alpha = 0.3) +
geom_area(aes(y = dens_pos), fill = "blue", alpha = 0.3) +
geom_vline(xintercept = crossover_log, linetype = "dashed", color = "black", size = 1) +
annotate("text", x = crossover_log, y = max(dens_mix) * 0.9,
label = paste0("Crossover = ", round(crossover_log, 2)), hjust = -0.1) +
labs(title = "Bayesian 2-Component Weibull Mixture Model Density (Log scale)",
x = "log(CHKV_AIU + 1)",
y = "Density") +
theme_minimal()
