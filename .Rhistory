library(rstan)
library(brms)
library(tidyverse)
library(Rsero)
library(mclust)
library(ggplot2)
library(dplyr)
library(ggplot2)
library(lme4)
options(mc.cores = parallel::detectCores())
rstan_options(auto_write = TRUE)
clinical_data<-read.csv("Adultfevers_qpcr_results(dataset).csv", stringsAsFactors = FALSE)
clinical_data %>%
summarise(across(c(chikv_nsp4, pan_flavi, chikv_nsp1, rvfv_mwaengo,),
~ sum(. != 0, na.rm = TRUE)))
chikv_positive <- clinical_data[
clinical_data$chikv_nsp4 > 0 &
clinical_data$chikv_nsp1 > 0,
]
# Check how many samples
nrow(chikv_positive)
clinical_data1<- read.csv("adult_abd(in).csv", stringsAsFactors = FALSE)
#merge the data sets
merged_clinicaldata <- merge(
clinical_data,
clinical_data1,
by.x = "serial",
by.y = "fk_serial",
all.x = TRUE
)
# Remove columns where all values are NA
clinical_data <- merged_clinicaldata[,
colSums(!is.na(merged_clinicaldata)) > 0]
# Check new structure
str(clinical_data)
dim(clinical_data)
clinical_data[clinical_data == ""] <- NA
clinical_data$date_admn  <- as.Date(clinical_data$date_admn, format = "%m/%d/%Y")
clinical_data$date_disch <- as.Date(clinical_data$date_disch, format = "%m/%d/%Y")
clinical_data$dob        <- as.Date(clinical_data$dob, format = "%m/%d/%Y")
#the first and last date of admission
first_admission <- min(clinical_data$date_admn, na.rm = TRUE)
last_admission  <- max(clinical_data$date_admn, na.rm = TRUE)
first_admission
last_admission
sum(clinical_data$weight == 0, na.rm = TRUE)
sum(clinical_data$height == 0, na.rm = TRUE)
sum(is.na(clinical_data$weight))
sum(is.na(clinical_data$height))
yn_vars <- c("fever", "cough", "chest_pain", "breathing_difficulty",
"headache", "nausea", "vomiting", "diarrhoea","appetite",
"skin_lesion", "jaundice", "pallor", "photophobia")
lapply(clinical_data[yn_vars], table)
clinical_data$age <- as.numeric(difftime(clinical_data$date_admn,
clinical_data$dob,
units = "days")) / 365.25
# Create binary positivity variables
clinical_data$chikv_pos <- ifelse(clinical_data$chikv_nsp1 > 0, 1, 0)
clinical_data$flavi_pos <- ifelse(clinical_data$pan_flavi > 0, 1, 0)
#Convert to factor (cleaner tables)
clinical_data$chikv_pos <- factor(clinical_data$chikv_pos, levels = c(0,1), labels = c("Negative","Positive"))
clinical_data$flavi_pos <- factor(clinical_data$flavi_pos, levels = c(0,1), labels = c("Negative","Positive"))
table(clinical_data$agecat, clinical_data$chikv_pos)
table(clinical_data$agecat, clinical_data$flavi_pos)
chikv_positive <- subset(clinical_data, chikv_pos == "Positive")
flavi_positive <- subset(clinical_data, flavi_pos == "Positive")
view(chikv_positive)
table(chikv_positive$fever)
sum(is.na(chikv_positive$fever_drn))
1260*150
2062-1260
(2062-1260)*150
700*150
500*150
560*150
565*150
570*150
570+1260
2062-1830
2062-1830
#Mean duration of fever
drn_fever <- mean(chikv_positive$duration_fever, na.rm = TRUE)
str(chikv_positive)
#Mean duration of fever
drn_fever <- mean(chikv_positive$fever_drn, na.rm = TRUE)
drn_fever
#Mean duration of fever
paste0(
"Mean: ", round(mean(chikv_positive$fever_drn, na.rm = TRUE), 2),
", SD: ", round(sd(chikv_positive$fever_drn, na.rm = TRUE), 2)
)
#Mean duration of fever
summary(chikv_positive$fever_drn)
#Mean duration of fever
median(chikv_positive$fever_drn, na.rm = TRUE)
quantile(chikv_positive$fever_drn, probs = c(0.25, 0.75), na.rm = TRUE)
IQR(chikv_positive$fever_drn, na.rm = TRUE)
view(chikv_positive)
#Mean temperature and standard
mean(chikv_positive$temp_axilla, na.rm = TRUE)
sd(chikv_positive$temp_axilla, na.rm = TRUE)d
sd(chikv_positive$temp_axilla, na.rm = TRUE)
unique(chikv_positive$diagnosis_1_category)
median(chikv_positive$appetite, na.rm = TRUE)
quantile(chikv_positive$appetite, probs = c(0.25, 0.75), na.rm = TRUE)
IQR(chikv_positive$appetite, na.rm = TRUE)
median(chikv_positive$cough_drn, na.rm = TRUE)
quantile(chikv_positive$cough_drn, probs = c(0.25, 0.75), na.rm = TRUE)
IQR(chikv_positive$cough_drn, na.rm = TRUE)
