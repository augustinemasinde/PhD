)
#option 2
post <- rstan::extract(fit_C, pars = "p_seropos")$p_seropos
p_seropos_mean <- colMeans(post)
serodata_all$p_seropos <- p_seropos_mean
B <- 1000
set.seed(123)
boot_site_age <- serodata_all %>%
group_by(site) %>%
group_modify(~{
n <- nrow(.x)
replicate(B, {
boot_sample <- .x[sample(1:n, n, replace = TRUE), ]
boot_sample %>%
mutate(
age_groups = cut(
ageyrs,
breaks = c(-Inf, 5, 15, 45, 65, Inf),
labels = c("<5", "5-14", "15-44", "45-64", "65+"),
right = FALSE
)
) %>%
group_by(age_groups) %>%
summarise(
seroprev_boot = mean(p_seropos),
.groups = "drop"
)
}, simplify = FALSE) %>%
bind_rows(.id = "bootstrap")
}) %>%
ungroup()
print(boot_site_age)
site_age_seroprev_boot <- boot_site_age %>%
group_by(site, age_groups) %>%
summarise(
seroprev_mean  = mean(seroprev_boot),
seroprev_lower = quantile(seroprev_boot, 0.025),
seroprev_upper = quantile(seroprev_boot, 0.975),
.groups = "drop"
)
print(site_age_seroprev_boot)
ggplot(site_age_seroprev_boot, aes(x = age_groups, y = seroprev_mean)) +
geom_point(size = 3, color = "steelblue") +
geom_errorbar(aes(ymin = seroprev_lower, ymax = seroprev_upper),
width = 0.2, color = "steelblue") +
facet_wrap(~ site, scales = "free_y") +
labs(
x = "Age group",
y = "Seroprevalence",
title = "Site-specific Age-stratified Seroprevalence"
) +
theme_minimal() +
theme(
axis.text.x = element_text(angle = 45, hjust = 1),
strip.text = element_text(face = "bold")
)
