library(rjags)
library(coda)
nr <- 8
na <- 5
ns <- 2
y  <- array(chikdata$chikspikepos, dim = c(na, nr, ns))
n  <- array(chikdata$n,           dim = c(na, nr, ns))
pw <- array(chikdata$pw,          dim = c(na, nr, ns))
model_string <- "
model{
# Likelihood with misclassification
for(i in 1:na){
for(j in 1:nr){
for(k in 1:ns){
y[i,j,k] ~ dbinom(
se * p[i,j,k] + (1 - sp) * (1 - p[i,j,k]),
n[i,j,k]
)
logit(p[i,j,k]) <- b0
+ u[i] - mean(u[])
+ v[j] - mean(v[])
+ w[k] - mean(w[])
}
}
}
# Informative priors for test performance
se ~ dbeta(30, 5)
sp ~ dbeta(25, 5)
# Age random effects (relaxed)
tau_a <- 1 / pow(sd_a, 2)
for(i in 1:na){
u[i] ~ dnorm(0, tau_a)
}
sd_a ~ dnorm(0, 2) T(0,)
# Region random effects
tau_r <- 1 / pow(sd_r, 2)
for(j in 1:nr){
v[j] ~ dnorm(0, tau_r)
}
sd_r ~ dnorm(0, 1) T(0,)
# Sex random effects
tau_s <- 1 / pow(sd_s, 2)
for(k in 1:ns){
w[k] ~ dnorm(0, tau_s)
}
sd_s ~ dnorm(0, 2) T(0,)
# Baseline prevalence (anchored)
b0 ~ dnorm(logit(0.2), 4)
# Predicted prevalence by age
for(i in 1:na){
age[i] <- inprod(p[i,1:nr,1:ns], pw[i,1:nr,1:ns]) /
sum(pw[i,1:nr,1:ns])
}
# Predicted prevalence by region
for(j in 1:nr){
region[j] <- inprod(p[1:na,j,1:ns], pw[1:na,j,1:ns]) /
sum(pw[1:na,j,1:ns])
}
# Predicted prevalence by sex
for(k in 1:ns){
sex[k] <- inprod(p[1:na,1:nr,k], pw[1:na,1:nr,k]) /
sum(pw[1:na,1:nr,k])
}
# National prevalence
national <- inprod(p[1:na,1:nr,1:ns],
pw[1:na,1:nr,1:ns])
}
"
model <- jags.model(
textConnection(model_string),
data = list(
y = y,
n = n,
pw = pw,
na = na,
nr = nr,
ns = ns
),
n.chains = 1,
inits = list(
.RNG.name = "base::Wichmann-Hill",
.RNG.seed = 999
)
)
update(model, 1000)
samp <- coda.samples(
model,
variable.names = c(
"age", "region", "sex",
"national", "se", "sp",
"sd_a", "sd_r", "sd_s"
),
n.iter = 10000
)
summary(samp)
